{
  "rewrites": [
    { "source": "/scales/:id", "destination": "/pages/scale-detail/index?id=:id" },
    { "source": "/assessments/:id", "destination": "/pages/assessment/index?id=:id" },
    { "source": "/reports/:key", "destination": "/pages/report/index?key=:key" },
    { "source": "/history", "destination": "/pages/history/index" },
    { "source": "/profile", "destination": "/pages/profile/index" }
  ],
  "headers": [
    {
      "source": "/scales/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600, s-maxage=86400" }
      ]
    },
    {
      "source": "/(.*).js",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*).css",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ],
  "trailingSlash": false
}
