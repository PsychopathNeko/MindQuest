{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/en", "destination": "/en.html" },
    { "source": "/history", "destination": "/history.html" },
    { "source": "/en/history", "destination": "/en/history.html" },
    { "source": "/about", "destination": "/about.html" },
    { "source": "/en/about", "destination": "/en/about.html" },
    { "source": "/scale/:id", "destination": "/scale/:id.html" },
    { "source": "/en/scale/:id", "destination": "/en/scale/:id.html" },
    { "source": "/en/:path*", "destination": "/en.html" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
