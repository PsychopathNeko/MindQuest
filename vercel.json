{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "cleanUrls": true,
  "rewrites": [
    { "source": "/assessment/:path*", "destination": "/index.html" },
    { "source": "/en/assessment/:path*", "destination": "/index.html" },
    { "source": "/report/:path*", "destination": "/index.html" },
    { "source": "/en/report/:path*", "destination": "/index.html" }
  ]
}
