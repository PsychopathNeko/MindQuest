{
  "meta": {
    "id": "brief-cope",
    "name": "Brief-COPE 简明应对方式问卷",
    "fullName": "Brief COPE Inventory",
    "description": "Brief-COPE 是一份包含 28 个条目的自评量表，测量人们在应对压力事件时使用的 14 种不同应对策略。它是完整版 COPE 问卷的简版，广泛应用于健康心理学和压力研究领域。",
    "author": "Carver (1997)",
    "license": "Free to use",
    "reference": "Carver CS. You want to measure coping but your protocol is too long: consider the Brief COPE. Int J Behav Med. 1997;4(1):92-100.",
    "instruction": "以下条目询问您在应对压力事件时的做法。每个条目描述了一种特定的应对方式。请根据您的实际情况，选择最符合您做法的选项。",
    "population": "成人（18岁以上）"
  },
  "commonChoices": [
    {
      "value": 1,
      "label": "我完全没有这样做"
    },
    {
      "value": 2,
      "label": "我偶尔这样做"
    },
    {
      "value": 3,
      "label": "我有时这样做"
    },
    {
      "value": 4,
      "label": "我经常这样做"
    }
  ],
  "questions": [
    {
      "index": 0,
      "text": "我通过投入工作或其他活动来转移注意力",
      "type": "likert"
    },
    {
      "index": 1,
      "text": "我集中精力去做一些事情来改善处境",
      "type": "likert"
    },
    {
      "index": 2,
      "text": "我对自己说\"这不是真的\"",
      "type": "likert"
    },
    {
      "index": 3,
      "text": "我借助酒精或其他药物来让自己感觉好一些",
      "type": "likert"
    },
    {
      "index": 4,
      "text": "我从他人那里获得情感上的支持",
      "type": "likert"
    },
    {
      "index": 5,
      "text": "我放弃了尝试去处理问题",
      "type": "likert"
    },
    {
      "index": 6,
      "text": "我采取行动来努力改善处境",
      "type": "likert"
    },
    {
      "index": 7,
      "text": "我拒绝相信事情已经发生了",
      "type": "likert"
    },
    {
      "index": 8,
      "text": "我说一些话来宣泄不愉快的感受",
      "type": "likert"
    },
    {
      "index": 9,
      "text": "我从他人那里获得帮助和建议",
      "type": "likert"
    },
    {
      "index": 10,
      "text": "我借助酒精或其他药物来帮助自己度过难关",
      "type": "likert"
    },
    {
      "index": 11,
      "text": "我试着从不同的角度看待问题，使它看起来更积极",
      "type": "likert"
    },
    {
      "index": 12,
      "text": "我批评自己",
      "type": "likert"
    },
    {
      "index": 13,
      "text": "我尝试制定应对策略",
      "type": "likert"
    },
    {
      "index": 14,
      "text": "我从某人那里获得安慰和理解",
      "type": "likert"
    },
    {
      "index": 15,
      "text": "我放弃了应对的努力",
      "type": "likert"
    },
    {
      "index": 16,
      "text": "我努力从正在发生的事情中寻找积极的一面",
      "type": "likert"
    },
    {
      "index": 17,
      "text": "我拿这件事开玩笑",
      "type": "likert"
    },
    {
      "index": 18,
      "text": "我做一些事情来少想一些，比如看电影、看电视、阅读、做白日梦、睡觉或购物",
      "type": "likert"
    },
    {
      "index": 19,
      "text": "我接受了事情已经发生的现实",
      "type": "likert"
    },
    {
      "index": 20,
      "text": "我表达自己的负面情绪",
      "type": "likert"
    },
    {
      "index": 21,
      "text": "我尝试从宗教或精神信仰中寻找安慰",
      "type": "likert"
    },
    {
      "index": 22,
      "text": "我尝试从他人那里获得关于该怎么做的建议或帮助",
      "type": "likert"
    },
    {
      "index": 23,
      "text": "我学着与之共处",
      "type": "likert"
    },
    {
      "index": 24,
      "text": "我认真思考该采取哪些步骤",
      "type": "likert"
    },
    {
      "index": 25,
      "text": "我因为发生的事情而责怪自己",
      "type": "likert"
    },
    {
      "index": 26,
      "text": "我祈祷或冥想",
      "type": "likert"
    },
    {
      "index": 27,
      "text": "我调侃这件事情",
      "type": "likert"
    }
  ],
