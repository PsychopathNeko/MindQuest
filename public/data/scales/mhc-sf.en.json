{
  "meta": {
    "id": "mhc-sf",
    "name": "MHC-SF Mental Health Continuum",
    "fullName": "Mental Health Continuum-Short Form",
    "description": "The MHC-SF is a 14-item self-report measure of positive mental health assessing emotional, social, and psychological well-being.",
    "author": "Keyes CLM (2005)",
    "license": "Free for research use",
    "reference": "Keyes CLM. Mental illness and/or mental health? Investigating axioms of the complete state model of health. J Consult Clin Psychol. 2005;73(3):539-548.",
    "instruction": "During the past month, how often did you feel..."
  },
  "commonChoices": [
    {
      "value": 0,
      "label": "Never"
    },
    {
      "value": 1,
      "label": "Once or twice"
    },
    {
      "value": 2,
      "label": "About once a week"
    },
    {
      "value": 3,
      "label": "About 2 or 3 times a week"
    },
    {
      "value": 4,
      "label": "Almost every day"
    },
    {
      "value": 5,
      "label": "Every day"
    }
  ],
  "questions": [
    {
      "index": 0,
      "text": "Happy",
      "type": "likert"
    },
    {
      "index": 1,
      "text": "Interested in life",
      "type": "likert"
    },
    {
      "index": 2,
      "text": "Satisfied with life",
      "type": "likert"
    },
    {
      "index": 3,
      "text": "That you had something important to contribute to society",
      "type": "likert"
    },
    {
      "index": 4,
      "text": "That you belonged to a community (like a social group, your school, or your neighborhood)",
      "type": "likert"
    },
    {
      "index": 5,
      "text": "That our society is becoming a better place for people",
      "type": "likert"
    },
    {
      "index": 6,
      "text": "That people are basically good",
      "type": "likert"
    },
    {
      "index": 7,
      "text": "That the way our society works makes sense to you",
      "type": "likert"
    },
    {
      "index": 8,
      "text": "That you liked most parts of your personality",
      "type": "likert"
    },
    {
      "index": 9,
      "text": "Good at managing the responsibilities of your daily life",
      "type": "likert"
    },
    {
      "index": 10,
      "text": "That you had warm and trusting relationships with others",
      "type": "likert"
    },
    {
      "index": 11,
      "text": "That you had experiences that challenged you to grow and become a better person",
      "type": "likert"
    },
    {
      "index": 12,
      "text": "Confident to think or express your own ideas and opinions",
      "type": "likert"
    },
    {
      "index": 13,
      "text": "That your life has a sense of direction or meaning to it",
      "type": "likert"
    }
  ],
