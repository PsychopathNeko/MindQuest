  "questions": [
    {
      "index": 0,
      "text": "当我需要帮助时，有一个特别的人在我身边",
      "type": "likert"
    },
    {
      "index": 1,
      "text": "有一个特别的人可以和我分享快乐和悲伤",
      "type": "likert"
    },
    {
      "index": 2,
      "text": "我的家人真的会尽力帮助我",
      "type": "likert"
    },
    {
      "index": 3,
      "text": "我从家人那里得到我需要的情感帮助和支持",
      "type": "likert"
    },
    {
      "index": 4,
      "text": "有一个特别的人是我真正的安慰来源",
      "type": "likert"
    },
    {
      "index": 5,
      "text": "我的朋友们真的会尽力帮助我",
      "type": "likert"
    },
    {
      "index": 6,
      "text": "当事情出差错时，我可以依靠我的朋友",
      "type": "likert"
    },
    {
      "index": 7,
      "text": "我可以和家人谈论我的问题",
      "type": "likert"
    },
    {
      "index": 8,
      "text": "我有朋友可以和他们分享快乐和悲伤",
      "type": "likert"
    },
    {
      "index": 9,
      "text": "在我生活中有一个特别的人关心我的感受",
      "type": "likert"
    },
    {
      "index": 10,
      "text": "我的家人愿意帮助我做决定",
      "type": "likert"
    },
    {
      "index": 11,
      "text": "我可以和朋友谈论我的问题",
      "type": "likert"
    }
