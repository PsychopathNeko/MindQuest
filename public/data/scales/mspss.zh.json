  "meta": {
    "id": "mspss",
    "name": "MSPSS 多维感知社会支持量表",
    "fullName": "Multidimensional Scale of Perceived Social Support",
    "description": "MSPSS 是一份包含 12 个条目的自评量表，评估个体从家庭、朋友和重要他人三个来源感知到的社会支持水平。",
    "author": "Zimet et al. (1988)",
    "license": "Free for research use",
    "reference": "Zimet GD, Dahlem NW, Zimet SG, Farley GK. The Multidimensional Scale of Perceived Social Support. J Pers Assess. 1988;52(1):30-41.",
    "instruction": "请仔细阅读以下每个陈述，并根据您的感受选择最符合的选项。",
    "population": "成人（18岁以上）"
  },
