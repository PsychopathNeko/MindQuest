  "interpretation": {
    "ranges": [
      {
        "min": 12,
        "max": 36,
        "level": "severe",
        "label": "低感知社会支持",
        "description": "您的得分提示您感知到来自家人、朋友和重要他人的社会支持水平较低。感知到社会支持不足是抑郁、焦虑和其他心理健康问题的重要风险因素。即使支持存在，感到不被支持也会非常令人痛苦。",
        "suggestions": [
          "考虑联系咨询师或治疗师，帮助加强您的支持网络",
          "找到一两个您可能愿意更多联系的人",
          "社区团体、志愿活动或支持小组有助于建立新的联系",
          "如果您感到孤立，心理健康专业人士可以帮助制定建立社交联系的策略"
        ]
      },
      {
        "min": 37,
        "max": 60,
        "level": "moderate",
        "label": "中度感知社会支持",
        "description": "您的得分表明感知到中等水平的社会支持。您有一些支持性的关系，但可能感到在某些方面支持不够一致或不够充分。加强这些联系可以增强您的心理韧性和幸福感。",
        "suggestions": [
          "识别哪些支持来源（家人、朋友、重要他人）最强，哪些可以加强",
          "练习向生活中的人表达您的需求；他人可能没有意识到您需要更多支持",
          "投入时间培养现有的人际关系",
          "考虑通过共同活动或社区参与来扩大社交网络"
        ]
      },
      {
        "min": 61,
        "max": 84,
        "level": "minimal",
        "label": "高感知社会支持",
        "description": "您的得分提示您感知到来自家人、朋友和/或重要他人的高水平社会支持。强烈的感知社会支持是心理健康的有力保护因素，与更强的心理韧性、更好的应对能力和更高的生活满意度相关。",
        "suggestions": [
          "继续培养为您提供支持的人际关系",
          "向支持您的人表达感激",
          "考虑反过来成为他人的支持来源"
        ]
      }
    ],
