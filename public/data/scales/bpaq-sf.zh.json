  "questions": [
    {
      "index": 0,
      "text": "如果被挑衅，我可能会打人",
      "type": "likert"
    },
    {
      "index": 1,
      "text": "如果有人打了我，我会还手",
      "type": "likert"
    },
    {
      "index": 2,
      "text": "面对威胁时我曾使用暴力来保护自己的权利",
      "type": "likert"
    },
    {
      "index": 3,
      "text": "当别人不同意我的时候，我忍不住和他们争论",
      "type": "likert"
    },
    {
      "index": 4,
      "text": "我的朋友说我有点爱争论",
      "type": "likert"
    },
    {
      "index": 5,
      "text": "我经常发现自己在和别人争辩",
      "type": "likert"
    },
    {
      "index": 6,
      "text": "有时候我会无缘无故感到烦躁",
      "type": "likert"
    },
    {
      "index": 7,
      "text": "我很难控制自己的脾气",
      "type": "likert"
    },
    {
      "index": 8,
      "text": "有时候我觉得自己就像一个即将爆炸的火药桶",
      "type": "likert"
    },
    {
      "index": 9,
      "text": "我有时候会觉得生活对我不公平",
      "type": "likert"
    },
    {
      "index": 10,
      "text": "当别人对我特别好时，我会怀疑他们想要什么",
      "type": "likert"
    },
    {
      "index": 11,
      "text": "我有时候会很嫉妒别人的好运",
      "type": "likert"
    }
