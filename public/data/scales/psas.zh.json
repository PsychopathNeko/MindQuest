{
  "meta": {
    "id": "psas",
    "name": "PSAS 睡前唤醒量表",
    "fullName": "Pre-Sleep Arousal Scale",
    "description": "PSAS 是一份包含16个条目的自评量表，用于评估试图入睡时的唤醒水平。它包括两个分量表：认知唤醒和躯体唤醒。",
    "author": "Nicassio et al. (1985)",
    "license": "Free to use",
    "reference": "Nicassio PM, Mendlowitz DR, Fussell JJ, Petras L. The phenomenology of the pre-sleep state: The development of the pre-sleep arousal scale. Behav Res Ther. 1985;23(3):263-271.",
    "instruction": "请描述当您在卧室试图入睡时，以下每种情况的体验程度。"
  },
  "commonChoices": [
    {
      "value": 1,
      "label": "完全没有"
    },
    {
      "value": 2,
      "label": "轻微"
    },
    {
      "value": 3,
      "label": "中等"
    },
    {
      "value": 4,
      "label": "很多"
    },
    {
      "value": 5,
      "label": "极度"
    }
  ],
  "questions": [
    {
      "index": 0,
      "text": "担心入睡",
      "type": "likert"
    },
    {
      "index": 1,
      "text": "回顾或思考当天的事件",
      "type": "likert"
    },
    {
      "index": 2,
      "text": "抑郁或焦虑的想法",
      "type": "likert"
    },
    {
      "index": 3,
      "text": "担心睡眠以外的问题",
      "type": "likert"
    },
    {
      "index": 4,
      "text": "精神警觉、活跃",
      "type": "likert"
    },
    {
      "index": 5,
      "text": "无法停止思考",
      "type": "likert"
    },
    {
      "index": 6,
      "text": "想法不断在脑中盘旋",
      "type": "likert"
    },
    {
      "index": 7,
      "text": "被环境中的声音干扰",
      "type": "likert"
    },
    {
      "index": 8,
      "text": "心跳加速、砰砰跳或不规则跳动",
      "type": "likert"
    },
    {
      "index": 9,
      "text": "身体有紧张不安的感觉",
      "type": "likert"
    },
    {
      "index": 10,
      "text": "呼吸急促或呼吸困难",
      "type": "likert"
    },
    {
      "index": 11,
      "text": "肌肉紧绷、紧张的感觉",
      "type": "likert"
    },
    {
      "index": 12,
      "text": "手、脚或身体发冷",
      "type": "likert"
    },
    {
      "index": 13,
      "text": "胃部不适（胃部打结或紧张感）",
      "type": "likert"
    },
    {
      "index": 14,
      "text": "手掌或身体其他部位出汗",
      "type": "likert"
    },
    {
      "index": 15,
      "text": "口腔或喉咽干燥",
      "type": "likert"
    }
  ],
  "scoring": {
    "method": "subscale",
    "maxTotal": 80,
    "maxItemScore": 5,
    "subscales": [
