{
  "meta": {
    "id": "pcl-5",
    "name": "PCL-5 创伤后应激障碍检查表",
    "fullName": "PTSD Checklist for DSM-5",
    "description": "PCL-5 是一份包含 20 个条目的自评量表，用于评估 DSM-5 定义的创伤后应激障碍（PTSD）症状的严重程度，包括侵入、回避、认知和情绪的负性改变以及唤醒和反应性的改变四个症状群。",
    "author": "Weathers et al. (2013)",
    "license": "Public Domain",
    "reference": "Weathers FW, Litz BT, Keane TM, Palmieri PA, Marx BP, Schnurr PP. The PTSD Checklist for DSM-5 (PCL-5). National Center for PTSD; 2013.",
    "instruction": "以下是人们在经历压力性经历后有时会出现的问题。请阅读每个问题，然后根据过去一个月内该问题困扰您的程度作答。",
    "population": "一般人群（16岁以上）"
  },
  "commonChoices": [
    {
      "value": 0,
      "label": "完全没有"
    },
    {
      "value": 1,
      "label": "有一点"
    },
    {
      "value": 2,
      "label": "中等程度"
    },
    {
      "value": 3,
      "label": "相当多"
    },
    {
      "value": 4,
      "label": "非常严重"
    }
  ],
  "questions": [
    {
      "index": 0,
      "text": "反复出现关于压力性经历的令人不安的记忆、想法或画面",
      "type": "likert"
    },
    {
      "index": 1,
      "text": "反复做关于压力性经历的令人不安的梦",
      "type": "likert"
    },
    {
      "index": 2,
      "text": "突然感觉或表现得好像压力性经历正在再次发生（好像您又回到了那个场景中）",
      "type": "likert"
    },
    {
      "index": 3,
      "text": "当某些事物提醒您压力性经历时，感到非常不安",
      "type": "likert"
    },
    {
      "index": 4,
      "text": "当某些事物提醒您压力性经历时，出现强烈的身体反应（如心跳加速、呼吸困难、出汗）",
      "type": "likert"
    },
    {
      "index": 5,
      "text": "回避关于压力性经历的记忆、想法或感受",
      "type": "likert"
    },
    {
      "index": 6,
      "text": "回避那些提醒您压力性经历的外部事物（如人、地点、对话、活动、物品或情境）",
      "type": "likert"
    },
    {
      "index": 7,
      "text": "难以记住压力性经历的重要部分",
      "type": "likert"
    },
    {
      "index": 8,
      "text": "对自己、他人或世界持有强烈的负面信念（如我很坏没有人可以信任世界是完全危险的）",
      "type": "likert"
    },
    {
      "index": 9,
      "text": "为压力性经历或之后发生的事情而责备自己或他人",
      "type": "likert"
    },
    {
      "index": 10,
      "text": "持续存在强烈的负面情绪（如恐惧、恐怖、愤怒、内疚或羞耻）",
      "type": "likert"
    },
    {
      "index": 11,
      "text": "对您曾经喜欢的活动失去兴趣",
      "type": "likert"
    },
    {
      "index": 12,
      "text": "感觉与他人疏远或隔绝",
      "type": "likert"
    },
    {
      "index": 13,
      "text": "难以体验积极情绪（如无法感到快乐，或对亲人没有爱的感觉）",
      "type": "likert"
    },
    {
      "index": 14,
      "text": "易怒的行为、愤怒的爆发或对人或物的攻击行为",
      "type": "likert"
    },
    {
      "index": 15,
      "text": "过度冒险或做可能伤害自己的事情",
      "type": "likert"
    },
    {
      "index": 16,
      "text": "过度警觉",
      "type": "likert"
    },
    {
      "index": 17,
      "text": "容易受惊",
      "type": "likert"
    },
    {
      "index": 18,
      "text": "难以集中注意力",
      "type": "likert"
    },
    {
      "index": 19,
      "text": "入睡或保持睡眠困难",
      "type": "likert"
    }
  ],
