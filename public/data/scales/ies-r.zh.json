  "questions": [
    {
      "index": 0,
      "text": "任何提醒都会唤起与之相关的感受",
      "type": "likert"
    },
    {
      "index": 1,
      "text": "我难以保持睡眠",
      "type": "likert"
    },
    {
      "index": 2,
      "text": "其他事情总让我想起它",
      "type": "likert"
    },
    {
      "index": 3,
      "text": "我感到烦躁和愤怒",
      "type": "likert"
    },
    {
      "index": 4,
      "text": "当我想到它或被提醒时，我避免让自己感到不安",
      "type": "likert"
    },
    {
      "index": 5,
      "text": "我不经意地就想到了它",
      "type": "likert"
    },
    {
      "index": 6,
      "text": "我觉得好像这件事没有发生过或不是真实的",
      "type": "likert"
    },
    {
      "index": 7,
      "text": "我远离与之相关的事物",
      "type": "likert"
    },
    {
      "index": 8,
      "text": "关于它的画面会闪入我的脑海",
      "type": "likert"
    },
    {
      "index": 9,
      "text": "我容易受惊、过度警觉",
      "type": "likert"
    },
    {
      "index": 10,
      "text": "我尽量不去想它",
      "type": "likert"
    },
    {
      "index": 11,
      "text": "我知道自己对此仍有很多感受，但我没有去处理",
      "type": "likert"
    },
    {
      "index": 12,
      "text": "我对此的感受有些麻木",
      "type": "likert"
    },
    {
      "index": 13,
      "text": "我发现自己表现或感觉像是回到了那个时候",
      "type": "likert"
    },
    {
      "index": 14,
      "text": "我难以入睡",
      "type": "likert"
    },
    {
      "index": 15,
      "text": "我会有一阵阵强烈的关于它的感受",
      "type": "likert"
    },
    {
      "index": 16,
      "text": "我试图把它从记忆中抹去",
      "type": "likert"
    },
    {
      "index": 17,
      "text": "我难以集中注意力",
      "type": "likert"
    },
    {
      "index": 18,
      "text": "与之相关的提醒会引起身体反应，如出汗、呼吸困难、恶心或心跳加速",
      "type": "likert"
    },
    {
      "index": 19,
      "text": "我做了关于它的梦",
      "type": "likert"
    },
    {
      "index": 20,
      "text": "我感到警觉和戒备",
      "type": "likert"
    },
    {
      "index": 21,
      "text": "我尽量不谈论它",
      "type": "likert"
    }
  ],
