    "name": "PSC-17 儿科症状检查表",
    "fullName": "儿科症状检查表-17",
    "description": "PSC-17是一份17题的简短筛查工具，用于评估儿童和青少年的内化问题、注意力问题和外化问题。",
    "author": "Jellinek MS, et al. (1988); Gardner W, et al. (1999)",
    "license": "Free to use",
    "reference": "Gardner W, et al. The PSC-17: A brief pediatric symptom checklist with psychosocial problem subscales. Ambulatory Child Health. 1999;5:225-236.",
    "instruction": "请根据您的孩子在过去一个月的表现，选择最符合的选项。",
    "population": "儿童青少年（4-18岁，家长填写）"
  },
  "commonChoices": [
    {
      "value": 0,
      "label": "从不"
    },
    {
      "value": 1,
      "label": "有时"
    },
    {
      "value": 2,
      "label": "经常"
    }
  ],
  "questions": [
    {
      "index": 0,
      "text": "感到悲伤、不开心。",
      "type": "likert"
    },
    {
      "index": 1,
      "text": "感到绝望。",
      "type": "likert"
    },
    {
      "index": 2,
      "text": "情绪低落或沮丧。",
      "type": "likert"
    },
    {
      "index": 3,
      "text": "过度担忧。",
      "type": "likert"
    },
    {
      "index": 4,
      "text": "看起来不太开心。",
      "type": "likert"
    },
    {
      "index": 5,
      "text": "坐立不安，无法安静坐着。",
      "type": "likert"
    },
    {
      "index": 6,
      "text": "白日做梦太多。",
      "type": "likert"
    },
    {
      "index": 7,
      "text": "容易分心。",
      "type": "likert"
    },
    {
      "index": 8,
      "text": "难以集中注意力。",
      "type": "likert"
    },
    {
      "index": 9,
      "text": "表现得好像被什么驱动一样。",
      "type": "likert"
    },
    {
      "index": 10,
      "text": "与他人打架。",
      "type": "likert"
    },
    {
      "index": 11,
      "text": "不遵守规则。",
      "type": "likert"
    },
    {
      "index": 12,
      "text": "不理解别人的感受。",
      "type": "likert"
    },
    {
      "index": 13,
      "text": "戏弄他人。",
      "type": "likert"
    },
    {
      "index": 14,
      "text": "责怪别人做了自己做的事。",
      "type": "likert"
    },
    {
      "index": 15,
      "text": "拒绝分享。",
      "type": "likert"
    },
    {
      "index": 16,
      "text": "未经允许拿别人的东西。",
      "type": "likert"
    }
  ],
