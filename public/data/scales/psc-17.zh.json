  "interpretation": {
    "ranges": [
      {
        "min": 0,
        "max": 14,
        "level": "normal",
        "label": "正常范围",
        "description": "您孩子的总分处于正常范围内，表明在所评估的各领域中没有显著的心理社会问题。在此范围内得分的儿童通常在情绪、行为和社交方面功能良好。",
        "suggestions": [
          "通过定期的开放式对话，继续监测孩子的情绪和行为健康",
          "保持一致的日常作息和适龄的期望，以支持持续的健康发展",
          "积极参与孩子的学校和同伴活动，强化积极的社交功能"
        ]
      },
      {
        "min": 15,
        "max": 34,
        "level": "elevated",
        "label": "临床显著",
        "description": "您孩子的总分已达到临床显著水平，提示存在有临床意义的心理社会困难，需要进一步的专业评估。请查看各分量表得分，以确定具体的关注领域。",
        "suggestions": [
          "咨询儿童心理健康专业人士，进行全面评估以确定具体问题领域",
          "查看分量表得分，确定内化、注意力还是外化问题最为突出",
          "与老师和学校辅导员沟通孩子在不同环境中的行为表现",
          "在寻求适当的专业指导的同时，保持支持性和非评判性的家庭环境",
          "考虑在三个月后再次完成PSC-17，以追踪任何干预后的变化"
        ]
      }
    ],
    "subscaleRanges": {
      "internalizing": [
        {
          "min": 0,
          "max": 4,
          "level": "normal",
          "label": "正常",
          "description": "您孩子的内化问题得分处于正常范围，表明没有显著的情绪困难，如悲伤、担忧或绝望感。处于此范围的儿童通常能够很好地应对其情绪体验。"
        },
        {
