  "questions": [
    {
      "index": 0,
      "text": "您多久感到疲倦一次？",
      "type": "likert"
    },
    {
      "index": 1,
      "text": "您多久感到身体疲惫一次？",
      "type": "likert"
    },
    {
      "index": 2,
      "text": "您多久感到情绪耗竭一次？",
      "type": "likert"
    },
    {
      "index": 3,
      "text": "您多久会想：我再也受不了了？",
      "type": "likert"
    },
    {
      "index": 4,
      "text": "您多久感到筋疲力尽一次？",
      "type": "likert"
    },
    {
      "index": 5,
      "text": "您多久感到虚弱且容易生病一次？",
      "type": "likert"
    },
    {
      "index": 6,
      "text": "您的工作在情感上令您感到疲惫吗？",
      "type": "likert"
    },
    {
      "index": 7,
      "text": "您是否因为工作而感到倦怠？",
      "type": "likert"
    },
    {
      "index": 8,
      "text": "您的工作让您感到沮丧吗？",
      "type": "likert"
    },
    {
      "index": 9,
      "text": "在工作日结束时，您是否感到筋疲力尽？",
      "type": "likert"
    },
    {
      "index": 10,
      "text": "早上一想到又要上班，您是否感到精疲力竭？",
      "type": "likert"
    },
    {
      "index": 11,
      "text": "您是否觉得工作的每一个小时都很累？",
      "type": "likert"
    },
    {
      "index": 12,
      "text": "您在休息时间是否有足够的精力留给家人和朋友？",
      "type": "likert"
    },
    {
      "index": 13,
      "text": "您觉得与来访者/患者一起工作困难吗？",
      "type": "likert"
    },
    {
      "index": 14,
      "text": "您觉得与来访者/患者一起工作令人沮丧吗？",
      "type": "likert"
    },
    {
      "index": 15,
      "text": "与来访者/患者一起工作是否消耗您的精力？",
      "type": "likert"
    },
    {
      "index": 16,
      "text": "您是否觉得在与来访者/患者工作时付出多于收获？",
      "type": "likert"
    },
    {
      "index": 17,
      "text": "您是否厌倦了与来访者/患者一起工作？",
      "type": "likert"
    },
    {
      "index": 18,
      "text": "您是否有时在想自己还能继续与来访者/患者工作多久？",
      "type": "likert"
    }
  ],
