    {
      "value": 3,
      "label": "有时"
    },
    {
      "value": 4,
      "label": "经常"
    },
    {
      "value": 5,
      "label": "几乎总是"
    }
  ],
  "questions": [
    {
      "index": 0,
      "text": "我觉得是我自己造成了这种经历",
      "type": "likert"
    },
    {
      "index": 1,
      "text": "我认为我必须接受发生的事情",
      "type": "likert"
    },
    {
      "index": 2,
      "text": "我经常想到我对所发生的事情有什么感受",
      "type": "likert"
    },
    {
      "index": 3,
      "text": "我想一些与此无关的愉快事情",
      "type": "likert"
    },
    {
      "index": 4,
      "text": "我想想我能从这种情况中学到什么",
      "type": "likert"
    },
    {
      "index": 5,
      "text": "我想这件事并没有那么糟糕，其他事情可能更糟",
      "type": "likert"
    },
    {
      "index": 6,
      "text": "我一直在想我犯了什么错误",
      "type": "likert"
    },
    {
      "index": 7,
      "text": "我想想自己能做些什么来改善这种情况",
      "type": "likert"
    },
    {
      "index": 8,
      "text": "我觉得是别人造成了这种情况",
      "type": "likert"
    },
    {
      "index": 9,
      "text": "我觉得我是那个应该为此负责的人",
      "type": "likert"
    },
    {
      "index": 10,
      "text": "我认为我必须接受这种情况",
      "type": "likert"
    },
    {
      "index": 11,
      "text": "我全神贯注于我对所经历事情的想法和感受",
      "type": "likert"
    },
    {
      "index": 12,
      "text": "我想一些愉快的事情而不是实际发生的事情",
      "type": "likert"
    },
    {
      "index": 13,
      "text": "我想这段经历也有积极的一面",
      "type": "likert"
    },
    {
      "index": 14,
      "text": "我想比起别人所经历的，这件事还不算太糟",
      "type": "likert"
    },
    {
      "index": 15,
      "text": "我不断地思考这有多么可怕",
      "type": "likert"
    },
    {
      "index": 16,
      "text": "我想想一个可以最好地处理这种情况的计划",
      "type": "likert"
    },
    {
      "index": 17,
      "text": "我觉得是别人应该为此负责",
      "type": "likert"
    }
  ],
