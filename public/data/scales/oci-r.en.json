{
  "meta": {
    "id": "oci-r",
    "name": "OCI-R Obsessive-Compulsive Inventory - Revised",
    "fullName": "Obsessive-Compulsive Inventory - Revised",
    "description": "The OCI-R is an 18-item self-report scale measuring OCD symptoms across six dimensions.",
    "author": "Foa, Huppert, Leiberg, et al. (2002)",
    "license": "Free to use",
    "reference": "Foa EB, et al. Psychol Assess. 2002;14(4):485-496.",
    "instruction": "For each statement, indicate how much it has distressed or bothered you during the past month.",
    "population": "Adults (18+)"
  },
  "commonChoices": [
    {
      "value": 0,
      "label": "Not at all"
    },
    {
      "value": 1,
      "label": "A little"
    },
    {
      "value": 2,
      "label": "Moderately"
    },
    {
      "value": 3,
      "label": "A lot"
    },
    {
      "value": 4,
      "label": "Extremely"
    }
  ],
  "questions": [
    {
      "index": 0,
      "text": "I have saved up so many things that they get in the way",
      "type": "likert"
    },
    {
      "index": 1,
      "text": "I check things more often than necessary",
      "type": "likert"
    },
    {
      "index": 2,
      "text": "I get upset if objects are not arranged properly",
      "type": "likert"
    },
    {
      "index": 3,
      "text": "I feel compelled to count while I am doing things",
      "type": "likert"
    },
    {
      "index": 4,
      "text": "I find it difficult to touch an object when I know it has been touched by strangers",
      "type": "likert"
    },
    {
      "index": 5,
      "text": "I find it difficult to control my own thoughts",
      "type": "likert"
    },
    {
      "index": 6,
      "text": "I collect things I do not need",
      "type": "likert"
    },
    {
      "index": 7,
      "text": "I repeatedly check doors, windows, drawers, etc.",
      "type": "likert"
    },
    {
      "index": 8,
      "text": "I get upset if others change the way I have arranged things",
      "type": "likert"
    },
    {
      "index": 9,
      "text": "I feel I have to repeat certain numbers",
      "type": "likert"
    },
    {
      "index": 10,
      "text": "I sometimes have to wash or clean myself simply because I feel contaminated",
      "type": "likert"
    },
    {
      "index": 11,
      "text": "I am upset by unpleasant thoughts that come into my mind against my will",
      "type": "likert"
    },
    {
      "index": 12,
      "text": "I avoid throwing things away because I am afraid I might need them later",
      "type": "likert"
    },
    {
      "index": 13,
      "text": "I repeatedly check gas and water taps and light switches after turning them off",
      "type": "likert"
    },
    {
      "index": 14,
      "text": "I need things to be arranged in a particular way",
      "type": "likert"
    },
    {
      "index": 15,
      "text": "I feel that there are good and bad numbers",
      "type": "likert"
    },
    {
      "index": 16,
      "text": "I wash my hands more often and longer than necessary",
      "type": "likert"
    },
    {
      "index": 17,
      "text": "I frequently get nasty thoughts and have difficulty getting rid of them",
      "type": "likert"
    }
  ],
