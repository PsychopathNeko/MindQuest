  "interpretation": {
    "ranges": [
      {
        "min": 20,
        "max": 100,
        "level": "unknown",
        "label": "请查看分量表",
        "description": "PANAS 总分为积极情绪与消极情绪之和，单一总分不具备明确的临床解释意义。请查看下方积极情绪（PA）和消极情绪（NA）分量表得分，以获得有意义的情绪评估。",
        "suggestions": [
          "查看积极情绪和消极情绪分量表得分以了解您的情绪状态",
          "理想的情绪模式是高积极情绪与低消极情绪的组合"
        ]
      }
    ],
    "subscaleRanges": {
      "positive_affect": [
        {
          "min": 10,
          "max": 20,
          "level": "severe",
          "label": "低",
          "description": "您的积极情感偏低，表明热情、活力和主动参与的体验减少。低积极情感是抑郁的标志性特征，可能预示着快感缺失——即难以体验愉悦。建议参与能够促进积极情绪的活动。"
        },
        {
          "min": 21,
          "max": 30,
          "level": "mild",
          "label": "中等",
          "description": "您的积极情感处于中等水平。您能体验到一些积极情绪，但仍有提升空间。行为激活——规划愉快且有意义的活动——有助于提升积极的情绪体验。"
        },
        {
          "min": 31,
          "max": 50,
          "level": "minimal",
          "label": "高",
          "description": "您的积极情感水平较高，表明您频繁体验到热情、兴趣和对生活的积极参与。高积极情感与更强的心理韧性、更好的社交关系和更佳的身体健康相关。"
        }
      ],
      "negative_affect": [
        {
          "min": 10,
          "max": 15,
          "level": "minimal",
          "label": "低",
          "description": "您的消极情感偏低，表明内疚、恐惧或敌意等痛苦情绪较少。低消极情感提示良好的情绪调节能力，与更高的生活满意度和心理健康水平相关。"
        },
        {
          "min": 16,
          "max": 25,
          "level": "normal",
          "label": "中等",
          "description": "您的消极情感处于中等范围。一定程度的消极情绪是正常人类体验的一部分。请关注是否有压力或特定情境在推动消极情感的升高。"
        },
        {
          "min": 26,
          "max": 50,
          "level": "severe",
          "label": "高",
          "description": "您的消极情感偏高，表明频繁体验到焦虑、愤怒、内疚或恐惧等痛苦情绪。持续偏高的消极情感与心理困扰相关，建议关注并寻求专业支持。"
        }
      ]
    }
