  "interpretation": {
    "ranges": [
      {
        "min": 20,
        "max": 50,
        "level": "mild",
        "label": "低整体情感",
        "description": "您的整体情绪参与度似乎有所降低，积极情感和消极情感的水平均较低。这种模式可能反映了情绪麻木、心理脱离或情绪强度低落的时期。探索能够促进情感活力的活动可能会有所帮助。",
        "suggestions": [
          "参与那些曾经给您带来快乐或兴奋的活动",
          "练习在一天中识别和标注您的情绪",
          "考虑这是否反映了暂时的状态，还是值得与专业人士探讨的持续性模式",
          "尝试新鲜的体验以激发情绪参与"
        ]
      },
      {
        "min": 51,
        "max": 100,
        "level": "normal",
        "label": "中等至高情感",
        "description": "您的情绪参与度处于正常范围内。请查看您的积极情感和消极情感分量表得分，以获得更细致的情绪平衡状况。理想的模式是高积极情感与低消极情感的组合。",
        "suggestions": [
          "查看您的分量表得分——目标是高积极情感和低消极情感",
          "练习能够增强积极情绪的活动，如运动、社交和追求兴趣爱好",
          "如果消极情感偏高，考虑使用压力管理技术，如深呼吸或渐进式放松"
        ]
      }
    ],
    "subscaleRanges": {
      "positive_affect": [
        {
          "min": 10,
          "max": 20,
          "level": "severe",
          "label": "低",
          "description": "您的积极情感偏低，表明热情、活力和主动参与的体验减少。低积极情感是抑郁的标志性特征，可能预示着快感缺失——即难以体验愉悦。建议参与能够促进积极情绪的活动。"
        },
        {
          "min": 21,
          "max": 30,
          "level": "mild",
          "label": "中等",
          "description": "您的积极情感处于中等水平。您能体验到一些积极情绪，但仍有提升空间。行为激活——规划愉快且有意义的活动——有助于提升积极的情绪体验。"
        },
        {
          "min": 31,
          "max": 50,
          "level": "minimal",
          "label": "高",
          "description": "您的积极情感水平较高，表明您频繁体验到热情、兴趣和对生活的积极参与。高积极情感与更强的心理韧性、更好的社交关系和更佳的身体健康相关。"
        }
      ],
      "negative_affect": [
        {
          "min": 10,
          "max": 15,
          "level": "minimal",
          "label": "低",
          "description": "您的消极情感偏低，表明内疚、恐惧或敌意等痛苦情绪较少。低消极情感提示良好的情绪调节能力，与更高的生活满意度和心理健康水平相关。"
        },
        {
          "min": 16,
          "max": 25,
          "level": "normal",
          "label": "中等",
          "description": "您的消极情感处于中等范围。一定程度的消极情绪是正常人类体验的一部分。请关注是否有压力或特定情境在推动消极情感的升高。"
        },
        {
          "min": 26,
          "max": 50,
          "level": "severe",
          "label": "高",
          "description": "您的消极情感偏高，表明频繁体验到焦虑、愤怒、内疚或恐惧等痛苦情绪。持续偏高的消极情感与心理困扰相关，建议关注并寻求专业支持。"
        }
      ]
    }
