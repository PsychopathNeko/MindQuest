  "meta": {
    "id": "bpaq-sf",
    "name": "BPAQ-SF Aggression Questionnaire Short Form",
    "fullName": "Buss-Perry Aggression Questionnaire Short Form",
    "description": "The BPAQ-SF is a 12-item self-report scale that assesses four dimensions of aggression: Physical Aggression, Verbal Aggression, Anger, and Hostility. It is the short form of the BPAQ-29, providing a concise and efficient measure for rapid aggression screening.",
    "author": "Bryant & Smith (2001)",
    "license": "Free for research use",
    "reference": "Bryant FB, Smith BD. Refining the architecture of aggression: a measurement model for the Buss-Perry Aggression Questionnaire. J Res Pers. 2001;35(2):138-167.",
    "instruction": "Please rate each statement based on your typical behavior and feelings.",
    "population": "Adults (18+)"
  },
  "commonChoices": [
    {
      "value": 1,
      "label": "Extremely Uncharacteristic"
    },
    {
      "value": 2,
      "label": "Somewhat Uncharacteristic"
    },
    {
      "value": 3,
      "label": "Neutral"
    },
    {
      "value": 4,
      "label": "Somewhat Characteristic"
    },
    {
      "value": 5,
      "label": "Extremely Characteristic"
    }
  ],
  "questions": [
    {
      "index": 0,
      "text": "Given enough provocation, I may hit another person",
      "type": "likert"
    },
    {
      "index": 1,
      "text": "If somebody hits me, I hit back",
      "type": "likert"
    },
    {
      "index": 2,
      "text": "I have threatened people I know when provoked",
      "type": "likert"
    },
    {
      "index": 3,
      "text": "When people disagree with me, I can’t help getting into an argument",
      "type": "likert"
    },
    {
      "index": 4,
      "text": "My friends say that I’m somewhat argumentative",
      "type": "likert"
    },
    {
      "index": 5,
      "text": "I often find myself disagreeing with people",
      "type": "likert"
    },
    {
      "index": 6,
      "text": "I sometimes feel irritable for no good reason",
      "type": "likert"
    },
    {
      "index": 7,
      "text": "I have trouble controlling my temper",
      "type": "likert"
    },
    {
      "index": 8,
      "text": "Sometimes I feel like a powder keg ready to explode",
      "type": "likert"
    },
    {
      "index": 9,
      "text": "I sometimes feel that life has treated me unfairly",
      "type": "likert"
    },
    {
      "index": 10,
      "text": "When people are especially nice, I wonder what they want",
      "type": "likert"
    },
    {
      "index": 11,
      "text": "I am sometimes eaten up with jealousy",
      "type": "likert"
    }
  ],
