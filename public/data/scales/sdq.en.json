  "interpretation": {
    "ranges": [
      {
        "min": 0,
        "max": 13,
        "level": "normal",
        "label": "Normal",
        "description": "Total difficulties score is within normal range (excluding prosocial subscale).",
        "suggestions": [
          "Continue monitoring the child's mental health development",
          "Maintain a supportive family communication environment"
        ]
      },
      {
        "min": 14,
        "max": 16,
        "level": "borderline",
        "label": "Borderline",
        "description": "Total difficulties score is at a borderline level. Monitoring is advised.",
        "suggestions": [
          "Monitor the child's behavioral and emotional changes closely",
          "Maintain communication with school teachers",
          "Consider a more detailed assessment"
        ]
      },
      {
        "min": 17,
        "max": 40,
        "level": "abnormal",
        "label": "Abnormal",
        "description": "Total difficulties score is elevated. Professional evaluation is recommended.",
        "suggestions": [
          "Consult a child mental health professional",
          "Focus on specific problem dimensions for targeted intervention",
          "Early intervention helps improve outcomes"
        ]
      }
    ],
