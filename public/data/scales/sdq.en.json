{
  "meta": {
    "id": "sdq",
    "name": "SDQ Strengths and Difficulties Questionnaire",
    "fullName": "Strengths and Difficulties Questionnaire",
    "description": "The SDQ is a 25-item scale assessing emotional symptoms, conduct problems, hyperactivity/inattention, peer relationship problems, and prosocial behavior in children and adolescents (aged 4-17).",
    "author": "Goodman R (1997)",
    "license": "Free to use",
    "reference": "Goodman R. The Strengths and Difficulties Questionnaire: a research note. J Child Psychol Psychiatry. 1997;38(5):581-586.",
    "instruction": "For each item, please mark the box that best describes the child's behavior over the last six months.",
    "population": "Children and adolescents (4-17, parent/teacher)"
  },
  "commonChoices": [
    {
      "value": 0,
      "label": "Not true"
    },
    {
      "value": 1,
      "label": "Somewhat true"
    },
    {
      "value": 2,
      "label": "Certainly true"
    }
  ],
  "questions": [
    {
      "index": 0,
      "text": "Considerate of other people's feelings.",
      "type": "likert"
    },
    {
      "index": 1,
      "text": "Restless, overactive, cannot stay still for long.",
      "type": "likert"
    },
    {
      "index": 2,
      "text": "Often complains of headaches, stomach-aches or sickness.",
      "type": "likert"
    },
    {
      "index": 3,
      "text": "Shares readily with other children (treats, toys, pencils etc.).",
      "type": "likert"
    },
    {
      "index": 4,
      "text": "Often has temper tantrums or hot tempers.",
      "type": "likert"
    },
    {
      "index": 5,
      "text": "Rather solitary, tends to play alone.",
      "type": "likert"
    },
    {
      "index": 6,
      "text": "Generally obedient, usually does what adults request.",
      "type": "likert"
    },
    {
      "index": 7,
      "text": "Many worries, often seems worried.",
      "type": "likert"
    },
    {
      "index": 8,
      "text": "Helpful if someone is hurt, upset or feeling ill.",
      "type": "likert"
    },
    {
      "index": 9,
      "text": "Constantly fidgeting or squirming.",
      "type": "likert"
    },
    {
      "index": 10,
      "text": "Has at least one good friend.",
      "type": "likert"
    },
    {
      "index": 11,
      "text": "Often fights with other children or bullies them.",
      "type": "likert"
    },
    {
      "index": 12,
      "text": "Often unhappy, down-hearted or tearful.",
      "type": "likert"
    },
    {
      "index": 13,
      "text": "Generally liked by other children.",
      "type": "likert"
    },
    {
      "index": 14,
      "text": "Easily distracted, concentration wanders.",
      "type": "likert"
    },
    {
      "index": 15,
      "text": "Nervous or clingy in new situations, easily loses confidence.",
      "type": "likert"
    },
    {
      "index": 16,
      "text": "Kind to younger children.",
      "type": "likert"
    },
    {
      "index": 17,
      "text": "Often lies or cheats.",
      "type": "likert"
    },
    {
      "index": 18,
      "text": "Picked on or bullied by other children.",
      "type": "likert"
    },
    {
      "index": 19,
      "text": "Often volunteers to help others (parents, teachers, other children).",
      "type": "likert"
    },
    {
      "index": 20,
      "text": "Thinks things out before acting.",
      "type": "likert"
    },
    {
      "index": 21,
      "text": "Steals from home, school or elsewhere.",
      "type": "likert"
    },
    {
      "index": 22,
      "text": "Gets on better with adults than with other children.",
      "type": "likert"
    },
    {
      "index": 23,
      "text": "Many fears, easily scared.",
      "type": "likert"
    },
    {
      "index": 24,
      "text": "Sees tasks through to the end, good attention span.",
      "type": "likert"
    }
  ],
