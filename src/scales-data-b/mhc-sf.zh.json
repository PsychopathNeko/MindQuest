      "text": "觉得人们基本上是善良的",
      "type": "likert"
    },
    {
      "index": 7,
      "text": "觉得社会的运作方式对自己有意义",
      "type": "likert"
    },
    {
      "index": 8,
      "text": "觉得自己喜欢自己个性的大部分方面",
      "type": "likert"
    },
    {
      "index": 9,
      "text": "善于管理日常生活中的责任",
      "type": "likert"
    },
    {
      "index": 10,
      "text": "与他人有温暖而信任的关系",
      "type": "likert"
    },
    {
      "index": 11,
      "text": "有推动自己成长和变得更好的经历",
      "type": "likert"
    },
    {
      "index": 12,
      "text": "有信心去思考或表达自己的想法和意见",
      "type": "likert"
    },
    {
      "index": 13,
      "text": "觉得自己的生活有方向和意义",
      "type": "likert"
    }
