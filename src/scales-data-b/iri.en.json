{
  "meta": {
    "id": "iri",
    "name": "IRI Empathy Scale",
    "fullName": "Interpersonal Reactivity Index",
    "description": "The IRI is a 28-item self-report measure of empathy assessing perspective taking, fantasy, empathic concern, and personal distress.",
    "author": "Davis MH (1983)",
    "license": "Free for research use",
    "reference": "Davis MH. Measuring individual differences in empathy. J Pers Soc Psychol. 1983;44(1):113-126.",
    "instruction": "Indicate how well each statement describes you.",
    "population": "Adults (18+)"
  },
  "commonChoices": [
    {
      "value": 0,
      "label": "Does not describe me well"
    },
    {
      "value": 1,
      "label": "Describes me slightly"
    },
    {
      "value": 2,
      "label": "Describes me somewhat"
    },
    {
      "value": 3,
      "label": "Describes me well"
    },
    {
      "value": 4,
      "label": "Describes me very well"
    }
  ],
  "questions": [
    {
      "index": 0,
      "text": "I daydream and fantasize, with some regularity, about things that might happen to me.",
      "type": "likert"
    },
    {
      "index": 1,
      "text": "I often have tender, concerned feelings for people less fortunate than me.",
      "type": "likert"
    },
    {
      "index": 2,
      "text": "I sometimes find it difficult to see things from the other guy’s point of view.",
      "type": "likert"
    },
    {
      "index": 3,
      "text": "Sometimes I don’t feel very sorry for other people when they are having problems.",
      "type": "likert"
    },
    {
      "index": 4,
      "text": "I really get involved with the feelings of the characters in a novel.",
      "type": "likert"
    },
    {
      "index": 5,
      "text": "In emergency situations, I feel apprehensive and ill-at-ease.",
      "type": "likert"
    },
    {
      "index": 6,
      "text": "I am usually objective when I watch a movie or play, and I don’t often get completely caught up in it.",
      "type": "likert"
    },
    {
      "index": 7,
      "text": "I try to look at everybody’s side of a disagreement before I make a decision.",
      "type": "likert"
    },
    {
      "index": 8,
      "text": "When I see someone being taken advantage of, I feel kind of protective towards them.",
      "type": "likert"
    },
    {
      "index": 9,
      "text": "I sometimes feel helpless when I am in the middle of a very emotional situation.",
      "type": "likert"
    },
    {
      "index": 10,
      "text": "I sometimes try to understand my friends better by imagining how things look from their perspective.",
      "type": "likert"
    },
    {
      "index": 11,
      "text": "Becoming extremely involved in a good book or movie is somewhat rare for me.",
      "type": "likert"
    },
    {
      "index": 12,
      "text": "When I see someone get hurt, I tend to remain calm.",
      "type": "likert"
    },
    {
      "index": 13,
      "text": "Other people’s misfortunes do not usually disturb me a great deal.",
      "type": "likert"
    },
    {
      "index": 14,
      "text": "If I’m sure I’m right about something, I don’t waste much time listening to other people’s arguments.",
      "type": "likert"
    },
    {
      "index": 15,
      "text": "After seeing a play or movie, I have felt as though I were one of the characters.",
      "type": "likert"
    },
    {
      "index": 16,
      "text": "Being in a tense emotional situation scares me.",
      "type": "likert"
    },
    {
      "index": 17,
      "text": "When I see someone being treated unfairly, I sometimes don’t feel very much pity for them.",
      "type": "likert"
    },
    {
      "index": 18,
      "text": "I am usually pretty effective in dealing with emergencies.",
      "type": "likert"
    },
    {
      "index": 19,
      "text": "I am often quite touched by things that I see happen.",
      "type": "likert"
    },
    {
      "index": 20,
      "text": "I believe that there are two sides to every question and try to look at them both.",
      "type": "likert"
    },
    {
      "index": 21,
      "text": "I would describe myself as a pretty soft-hearted person.",
      "type": "likert"
    },
    {
      "index": 22,
      "text": "When I watch a good movie, I can very easily put myself in the place of a leading character.",
      "type": "likert"
    },
    {
      "index": 23,
      "text": "I tend to lose control during emergencies.",
      "type": "likert"
    },
    {
      "index": 24,
      "text": "When I’m upset at someone, I usually try to put myself in his shoes for a while.",
      "type": "likert"
    },
    {
      "index": 25,
      "text": "When I am reading an interesting story or novel, I imagine how I would feel if the events were happening to me.",
      "type": "likert"
    },
    {
      "index": 26,
      "text": "When I see someone who badly needs help in an emergency, I go to pieces.",
      "type": "likert"
    },
    {
      "index": 27,
      "text": "Before criticizing somebody, I try to imagine how I would feel if I were in their place.",
      "type": "likert"
    }
  ],
