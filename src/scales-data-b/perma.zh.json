  "questions": [
    {
      "index": 0,
      "text": "您多久感受到积极正面的情绪？",
      "type": "likert"
    },
    {
      "index": 1,
      "text": "您多久会因为感兴趣而完全沉浸在正在做的事情中？",
      "type": "likert"
    },
    {
      "index": 2,
      "text": "您多久感到被爱？",
      "type": "likert"
    },
    {
      "index": 3,
      "text": "您多久觉得自己做的事情是有价值和有意义的？",
      "type": "likert"
    },
    {
      "index": 4,
      "text": "总体而言，您在多大程度上感到快乐？",
      "type": "likert"
    },
    {
      "index": 5,
      "text": "您通常在多大程度上全身心投入到您所做的事情中？",
      "type": "likert"
    },
    {
      "index": 6,
      "text": "您在多大程度上受到社交关系的支持？",
      "type": "likert"
    },
    {
      "index": 7,
      "text": "您多久在朝着目标前进时感到进展顺利？",
      "type": "likert"
    },
    {
      "index": 8,
      "text": "您多久能够处理好自己的责任？",
      "type": "likert"
    },
    {
      "index": 9,
      "text": "您通常在多大程度上感到自己所做的事情令人兴奋和有趣？",
      "type": "likert"
    },
    {
      "index": 10,
      "text": "您在多大程度上觉得自己的生活有方向感和意义？",
      "type": "likert"
    },
    {
      "index": 11,
      "text": "总体而言，您在多大程度上感到满足？",
      "type": "likert"
    },
    {
      "index": 12,
      "text": "您对自己的社交关系在多大程度上感到满意？",
      "type": "likert"
    },
    {
      "index": 13,
      "text": "您多久觉得自己达成了目标？",
      "type": "likert"
    },
    {
      "index": 14,
      "text": "您在多大程度上觉得自己过着有目的的生活？",
      "type": "likert"
    },
    {
      "index": 15,
      "text": "您多久感到焦虑？",
      "type": "likert"
    },
    {
      "index": 16,
      "text": "您多久感到愤怒？",
      "type": "likert"
    },
    {
      "index": 17,
      "text": "您多久感到悲伤？",
      "type": "likert"
    },
    {
      "index": 18,
      "text": "总体而言，您如何评价自己的健康状况？",
      "type": "likert"
    },
    {
      "index": 19,
      "text": "与同龄人相比，您对自己的健康状况满意吗？",
      "type": "likert"
    },
    {
      "index": 20,
      "text": "您的健康状况是否允许您做想做的事情？",
      "type": "likert"
    },
    {
      "index": 21,
      "text": "您在多大程度上感到孤独？",
      "type": "likert"
    },
    {
      "index": 22,
      "text": "总体而言，您在多大程度上感到幸福？",
      "type": "likert"
    }
  ],
