{
  "meta": {
    "id": "docs",
    "name": "DOCS 强迫症维度量表",
    "fullName": "Dimensional Obsessive-Compulsive Scale",
    "description": "DOCS 是一份包含20个条目的自评量表，从四个维度评估强迫症状严重程度：污染、伤害责任、不可接受的想法和对称/排列。",
    "author": "Abramowitz JS, et al. (2010)",
    "license": "Free to use",
    "reference": "Abramowitz JS, et al. Psychol Assess. 2010;22(1):180-198.",
    "instruction": "以下问题涉及四种不同类型的困扰。请根据过去一个月的实际体验进行评分。",
    "population": "成人（18岁以上）"
  },
  "commonChoices": [
    {
      "value": 0,
      "label": "没有症状/完全没有"
    },
    {
      "value": 1,
      "label": "轻微/偶尔"
    },
    {
      "value": 2,
      "label": "中等/有时"
    },
    {
      "value": 3,
      "label": "严重/经常"
    },
    {
      "value": 4,
      "label": "极其严重/持续不断"
    }
  ],
  "questions": [
    {
      "index": 0,
      "text": "您花了多少时间在污染（灰尘、细菌、化学物质）的想法上？",
      "type": "likert"
    },
    {
      "index": 1,
      "text": "为避免污染担忧，您回避了多少情境？",
      "type": "likert"
    },
    {
      "index": 2,
      "text": "有污染想法但无法清洗时，您多么焦虑？",
      "type": "likert"
    },
    {
      "index": 3,
      "text": "污染担忧和清洗行为在多大程度上干扰了日常生活？",
      "type": "likert"
    },
    {
      "index": 4,
      "text": "忽视污染想法并克制清洗行为有多困难？",
      "type": "likert"
    },
    {
      "index": 5,
      "text": "您花了多少时间想自己是否要对可怕的事负责？",
      "type": "likert"
    },
    {
      "index": 6,
      "text": "为避免为伤害负责，您回避了多少情境？",
      "type": "likert"
    },
    {
      "index": 7,
      "text": "无法检查或寻求保证时，您多么焦虑？",
      "type": "likert"
    },
    {
      "index": 8,
      "text": "伤害想法和检查行为在多大程度上干扰了日常生活？",
      "type": "likert"
    },
    {
      "index": 9,
      "text": "忽视伤害责任想法并克制检查行为有多困难？",
      "type": "likert"
    },
    {
      "index": 10,
      "text": "您花了多少时间在不想要的侵入性想法上？",
      "type": "likert"
    },
    {
      "index": 11,
      "text": "为避免侵入性想法，您回避了多少情境？",
      "type": "likert"
    },
    {
      "index": 12,
      "text": "有不可接受的想法且无法执行仪式时，您多么焦虑？",
      "type": "likert"
    },
    {
      "index": 13,
      "text": "不可接受的想法和仪式在多大程度上干扰了日常生活？",
      "type": "likert"
    },
    {
      "index": 14,
      "text": "忽视不可接受的想法并克制仪式有多困难？",
      "type": "likert"
    },
    {
      "index": 15,
      "text": "您花了多少时间在对称、秩序或平衡的需求上？",
      "type": "likert"
    },
    {
      "index": 16,
      "text": "为避免对称担忧，您回避了多少情境？",
      "type": "likert"
    },
    {
      "index": 17,
      "text": "无法排列物品以达到对称时，您多么焦虑？",
      "type": "likert"
    },
    {
      "index": 18,
      "text": "对称担忧和排列行为在多大程度上干扰了日常生活？",
      "type": "likert"
    },
    {
      "index": 19,
      "text": "忽视对称想法并克制排列行为有多困难？",
      "type": "likert"
    }
  ],
  "scoring": {
