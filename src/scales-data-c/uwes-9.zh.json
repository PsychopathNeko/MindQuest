  "questions": [
    {
      "index": 0,
      "text": "在工作中，我感到精力充沛。",
      "type": "likert"
    },
    {
      "index": 1,
      "text": "我觉得自己的工作充满意义和目标。",
      "type": "likert"
    },
    {
      "index": 2,
      "text": "时间在工作中飞逝。",
      "type": "likert"
    },
    {
      "index": 3,
      "text": "在工作时，我感到强壮和有活力。",
      "type": "likert"
    },
    {
      "index": 4,
      "text": "我对自己的工作充满热情。",
      "type": "likert"
    },
    {
      "index": 5,
      "text": "当我工作时，我忘记了周围的一切。",
      "type": "likert"
    },
    {
      "index": 6,
      "text": "我的工作给了我灵感。",
      "type": "likert"
    },
    {
      "index": 7,
      "text": "当我早上起床时，我想去工作。",
      "type": "likert"
    },
    {
      "index": 8,
      "text": "当我全身心投入工作时，我感到快乐。",
      "type": "likert"
    }
