        "name": "差距感",
        "items": [
          4,
          5,
          6,
          7
        ],
        "maxScore": 28
      }
    ]
  },
  "interpretation": {
    "ranges": [
      {
        "min": 8,
        "max": 28,
        "level": "minimal",
        "label": "非完美主义",
        "description": "您的完美主义倾向较低，对自身要求不高。",
        "suggestions": [
